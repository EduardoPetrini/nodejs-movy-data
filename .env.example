# Movy — Environment Variables
#
# Copy this file to .env and fill in the values for your migration scenario.
# Any variable set here pre-fills the corresponding CLI prompt automatically.
# Variables not provided will be collected interactively at runtime.
#
# Pattern: {SOURCE|TARGET}_{DBTYPE}_{FIELD}
#   Roles:   SOURCE | TARGET
#   Types:   POSTGRES | MYSQL
#   Fields:  HOSTNAME | PORT | USERNAME | PASSWORD | DATABASE
#
# The CLI auto-detects the database type from whichever {ROLE}_{TYPE}_*
# variables are present, so you only need to populate the block that
# matches your actual source and target engines.
#
# Leave unused sections commented out or remove them entirely.

# ---------------------------------------------------------------------------
# Scenario A — PostgreSQL → PostgreSQL (same-engine migration)
# ---------------------------------------------------------------------------
# SOURCE_POSTGRES_HOSTNAME=localhost
# SOURCE_POSTGRES_PORT=5432
# SOURCE_POSTGRES_USERNAME=postgres
# SOURCE_POSTGRES_PASSWORD=secret
# SOURCE_POSTGRES_DATABASE=source_db

# TARGET_POSTGRES_HOSTNAME=localhost
# TARGET_POSTGRES_PORT=5433
# TARGET_POSTGRES_USERNAME=postgres
# TARGET_POSTGRES_PASSWORD=secret
# TARGET_POSTGRES_DATABASE=target_db

# ---------------------------------------------------------------------------
# Scenario B — MySQL → MySQL (same-engine migration)
# ---------------------------------------------------------------------------
# SOURCE_MYSQL_HOSTNAME=localhost
# SOURCE_MYSQL_PORT=3306
# SOURCE_MYSQL_USERNAME=root
# SOURCE_MYSQL_PASSWORD=secret
# SOURCE_MYSQL_DATABASE=source_db

# TARGET_MYSQL_HOSTNAME=localhost
# TARGET_MYSQL_PORT=3307
# TARGET_MYSQL_USERNAME=root
# TARGET_MYSQL_PASSWORD=secret
# TARGET_MYSQL_DATABASE=target_db

# ---------------------------------------------------------------------------
# Scenario C — MySQL → PostgreSQL (cross-engine migration)
# ---------------------------------------------------------------------------
# SOURCE_MYSQL_HOSTNAME=localhost
# SOURCE_MYSQL_PORT=3306
# SOURCE_MYSQL_USERNAME=root
# SOURCE_MYSQL_PASSWORD=secret
# SOURCE_MYSQL_DATABASE=source_db

# TARGET_POSTGRES_HOSTNAME=localhost
# TARGET_POSTGRES_PORT=5432
# TARGET_POSTGRES_USERNAME=postgres
# TARGET_POSTGRES_PASSWORD=secret
# TARGET_POSTGRES_DATABASE=target_db

# ---------------------------------------------------------------------------
# Scenario D — PostgreSQL → MySQL (cross-engine migration)
# ---------------------------------------------------------------------------
# SOURCE_POSTGRES_HOSTNAME=localhost
# SOURCE_POSTGRES_PORT=5432
# SOURCE_POSTGRES_USERNAME=postgres
# SOURCE_POSTGRES_PASSWORD=secret
# SOURCE_POSTGRES_DATABASE=source_db

# TARGET_MYSQL_HOSTNAME=localhost
# TARGET_MYSQL_PORT=3306
# TARGET_MYSQL_USERNAME=root
# TARGET_MYSQL_PASSWORD=secret
# TARGET_MYSQL_DATABASE=target_db

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
# NODE_ENV=production   # Use compiled JS from dist/ instead of ts-node
# DEBUG=true            # Enable verbose debug output in the console
